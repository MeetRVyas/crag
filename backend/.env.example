DATABASE_URL=sqlite:///./data/crag.db
REDIS_URL=redis://redis:6379/0

PROVIDER=ollama # or huggingface or anthropic or groq
EMBEDDING_PROVIDER=ollama # or huggingface

TAVILY_API_KEY=your-tavily-api-key
HF_TOKEN=your-hf-token

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
LLM_MODEL=llama3.1:8b
EMBEDDING_MODEL=embeddinggemma:300m

EMBEDDING_FALLBACK=ollama

OLLAMA_ALLOWED_LLM_MODELS=["llama3.1:8b","phi3:mini","mistral:v0.3","qwen2.5:1.5b"]
OLLAMA_ALLOWED_EMBEDDING_MODELS=["nomic-embed-text","embeddinggemma:300m"]

# HuggingFace
# HUGGINGFACEHUB_API_TOKEN=your-huggingface-api-key
## CPU
# LLM_MODEL=Qwen/Qwen2.5-3B-Instruct # CPU
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2 # CPU
## API
# LLM_MODEL=HuggingFaceH4/zephyr-7b-beta
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5 # Not recommended (rate limited)


# Google
# GOOGLE_API_KEY=your-google-api-key
# EMBEDDING_MODEL=models/embedding-001
# LLM_MODEL=gemini-1.5-flash


# Groq LLM
# GROQ_API_KEY=your-groq-api-key
